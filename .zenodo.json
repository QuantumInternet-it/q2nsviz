{
  "title": "Q2NSViz: Quantum Network Trace Visualizer",
  "upload_type": "software",
  "version": "0.1.0",
  "license": "mit-license",
  "description": "<p><strong>Q2NSViz</strong> is a desktop companion for <a href=\"https://github.com/QuantumInternet-it/q2ns\">Q2NS</a> that replays JSON trace files into an interactive, time-stepped view of quantum network protocols. It jointly renders physical- and entanglement-connectivity graphs and supports entangled-state manipulations, enabling an intuitive inspection of entanglement dynamics and protocol behavior.</p>",
